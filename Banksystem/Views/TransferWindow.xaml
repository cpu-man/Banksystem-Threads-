<Window x:Class="Banksystem.Views.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Banksystem.ViewModels"
        Title="Overfør beløb"
        Height="440" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:TransferViewModel />
    </Window.DataContext>

    <DockPanel Margin="30">

        <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Annuller"
                    Height="38"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2"
                    Content="Godkend overførsel"
                    Height="38"
                    Background="LightSeaGreen"
                    Foreground="White"
                    FontWeight="Bold"
                    Command="{Binding TransferCommand}"/>
        </Grid>

        <!-- Status besked -->
        <Border DockPanel.Dock="Bottom"
                CornerRadius="4" Padding="12,8"
                Margin="0,0,0,8"
                Visibility="{Binding StatusVisibility}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                            <Setter Property="Background" Value="#F0FDF4"/>
                            <Setter Property="BorderBrush" Value="#86EFAC"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                            <Setter Property="Background" Value="#FEF2F2"/>
                            <Setter Property="BorderBrush" Value="#FECACA"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                <Setter Property="Foreground" Value="#15803D"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                <Setter Property="Foreground" Value="#B91C1C"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <StackPanel>
            <TextBlock Text="Overfør beløb"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Udfyld oplysningerne nedenfor"
                       Foreground="Gray"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Fra konto" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox Height="35" Margin="0,0,0,14"
                      ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedFromAccount}"
                      DisplayMemberPath="DisplayName"/>

            <TextBlock Text="Til konto" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox Height="35" Margin="0,0,0,14"
                      ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedToAccount}"
                      DisplayMemberPath="DisplayName"/>

            <TextBlock Text="Beløb (DKK)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="AmountBox" Height="35" Padding="8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="AmountBox_PreviewTextInput"/>
        </StackPanel>

    </DockPanel>
</Window>